{
  "Logging": {
      "LogLevel": {
        "Default": "Information"
      }
  },

  "ConnectionStringName": "Default",

  "Monetary": {
    "PlatformCurrency": "IRR"
  },

  "ConnectionStrings": {
    "Default": "Host={DB_ADDRESS};Database=refahi-db;Username={DB_USER};Password={DB_PASSWORD}"
  },

  "Jwt": {
    "Key": "{REFAHIPLUS_JWT_KEY}",
    "Issuer": "refahi-identity",
    "Audience": "refahi-api",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryMinutes": 10080,
    "ClockSkewSeconds": 30
  },

  "Identity": {
    "AutoRegistrationEnabled": true,
    "QuickRegistrationEnabled": true
  },

  "CacheService": {
    "Type": "InMemory",
    "Redis": {
      "ConnectionString": ""
    }
  },

  "NotificationService": {
    "UseInMemory": true,
    "BaseUrl": "http://prod_notif"
  },

  "MediaStorage": {
    "BasePath": "C:\\refahi-media-storage",
    "CreateBaseUrl": "",
    "LoadBaseUrl": "https://media.refahiplus.com",
    "MaxImageSizeBytes": 10485760,
    "MaxVideoSizeBytes": 209715200
  },

  "Hotels": {
    "Providers": {
      "SnappTrip": {
        "BaseUrl": "https://b2bapiv2.snapptrip.com/",
        "ApiKey": "{REFAHIPLUS_SNAPPTRIP_API_KEY}",
        "TimeoutSeconds": 20,
        "RetryCount": 3,
        "RetryDelayMilliseconds": 300,
        "CircuitBreakerFailuresBeforeTrip": 5,
        "CircuitBreakerDurationSeconds": 30,
        "BulkheadMaxParallelization": 50,
        "BulkheadMaxQueuedActions": 100
      }
    }
  },

  "Flights": {
    "Providers": {
      "SnappTrip": {
        "BaseUrl": "https://b2bapiv2.snapptrip.com/flight/",
        "ApiBasePath": "api/v1",
        "ApiKey": "{REFAHIPLUS_SNAPPTRIP_FLIGHT_API_KEY}",
        "TimeoutSeconds": 20,
        "RetryCount": 3,
        "RetryDelayMilliseconds": 300,
        "CircuitBreakerFailuresBeforeTrip": 5,
        "CircuitBreakerDurationSeconds": 30,
        "BulkheadMaxParallelization": 50,
        "BulkheadMaxQueuedActions": 100
      }
    }
  },

  "Charge": {
    "PublicCatalogRateLimit": {
      "PermitLimit": 30,
      "WindowSeconds": 60
    },
    "RequestTtlMinutes": 20,
    "Providers": {
      "Eniac": {
        "BaseUrl": "https://vms.kishcharge.ir/",
        "Username": "{REFAHIPLUS_ENIAC_USERNAME}",
        "Password": "{REFAHIPLUS_ENIAC_PASSWORD}",
        "ChannelId": 102,
        "ResellerName": "رفاهی پلاس",
        "TimeoutSeconds": 30,
        "TokenRefreshSkewSeconds": 120,
        "UnresolvedTimeoutHours": 24,
        "UnresolvedAction": "ManualReview"
      }
    }
  },

  "PaymentGateway": {
    "PublicBaseUrl": "https://refahiplus.com",
    "Providers": {
      "Sep": {
        "TerminalId": "{REFAHIPLUS_SEP_TERMINAL_ID}",
        "TokenUrl": "https://sep.shaparak.ir/onlinepg/onlinepg",
        "PaymentBaseUrl": "https://sep.shaparak.ir/OnlinePG/SendToken",
        "VerifyUrl": "https://sep.shaparak.ir/verifyTxnRandomSessionkey/ipg/VerifyTransaction",
        "ReverseUrl": "https://sep.shaparak.ir/verifyTxnRandomSessionkey/ipg/ReverseTransaction",
        "SessionExpiryMinutes": 15,
        "TimeoutSeconds": 30,
        "RetryCount": 3,
        "RetryDelayMilliseconds": 500,
        "CircuitBreakerFailuresBeforeTrip": 5,
        "CircuitBreakerDurationSeconds": 30
      },
      "Jibit": {
        "ApiKey": "{REFAHIPLUS_JIBIT_API_KEY}",
        "SecretKey": "{REFAHIPLUS_JIBIT_SECRET_KEY}",
        "BaseUrl": "https://napi.jibit.ir/ppg/v3",
        "SessionExpiryMinutes": 15,
        "TimeoutSeconds": 30,
        "RetryCount": 3,
        "RetryDelayMilliseconds": 500,
        "CircuitBreakerFailuresBeforeTrip": 5,
        "CircuitBreakerDurationSeconds": 30
      }
    }
  }
}
